    },
    "CFBundleName" : {
      "comment" : "Bundle name",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "VoiceDrop"
          }
        }
      }
    },
    "NSCameraUsageDescription" : {
      "comment" : "Privacy - Camera Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VoiceDrop can take a photo of the scene while you record, saved alongside the recording."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VoiceDrop 可在录音过程中拍摄场景照片，随录音一起保存。"
          }
        }
      }
    },
    "NSLocationWhenInUseUsageDescription" : {
      "comment" : "Privacy - Location When In Use Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VoiceDrop puts your current location (city / district) into the recording's file name so it's easy to recognize later. You can decline — recording works either way."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VoiceDrop 把当前位置（如城市/城区）写进录音文件名，方便日后辨认。可拒绝，录音照常。"
          }
        }
      }
    },
    "NSMicrophoneUsageDescription" : {
      "comment" : "Privacy - Microphone Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VoiceDrop records what you say and uploads it to your own file relay."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VoiceDrop 录下你的口述，并上传到你的文件中转站。"
          }
        }
      }
    },
    "NSPhotoLibraryAddUsageDescription" : {
      "comment" : "Privacy - Photo Library Additions Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VoiceDrop also saves the scene photos you take to your system photo library."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VoiceDrop 把你拍的场景照片在系统相册里也存一份。"
          }
        }
      }
    },
    "NSSpeechRecognitionUsageDescription" : {
      "comment" : "Privacy - Speech Recognition Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VoiceDrop uses speech recognition to turn your spoken edit requests into text and send them to the server."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VoiceDrop 用语音识别把你对文章的修改要求转成文字，发给服务器。"
          }
        }
      }
    }
  },
  "version" : "1.0"
}