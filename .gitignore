# `fastlane release` uploads. Only frameit's generated extras are ignored.
fastlane/screenshots/**/*_framed.png
fastlane/screenshots/**/.frameit

.DS_Store

# Agent / editor state
.claude/

# Downloaded VoiceDrop recordings (personal audio — never commit)
archive/

# Xcode build / fastlane screenshot derived data
build/

# Python bytecode
__pycache__/
*.pyc
.gstack/

